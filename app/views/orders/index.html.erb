<% content_for :title, "All Orders" %>
<%content_for :_1st, "Orders" %>
<%content_for :_2nd, "All Orders" %>


<h1>All Orders</h1>

<table class="table table-striped">
  <thead>
    <tr>
      <th>#</th>
      <th>User</th>
      <th>Total Amount</th>
      <th>Status</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @orders.each do |order| %>
      <tr>
        <td><%= order.id %></td>
        <td><%= order.email %></td>
        <td><%= number_to_currency(order.total_amount) %></td>
        <td><%= order.status %></td>
        <td><%= link_to "View", order_path(order) %></td>
      </tr>
    <% end %>
  </tbody>
</table>