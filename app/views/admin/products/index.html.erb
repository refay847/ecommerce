<% content_for :title, "Admin Products" %>
<% content_for :_1st, "Admin Products" %>
<% content_for :_2nd, "Admin Products" %>
<!-- products -->
<div class="product-section mt-150 mb-150">
  <div class="container">
    <!-- Admin Actions -->
    <div class="row mb-4">
      <div class="col-md-6">
        <%= link_to "Manage Categories",
            admin_categories_path,
            class: "btn btn-secondary" %>
      </div>
      <div class="col-md-6 text-end">
        <%= link_to "Add New Product",
            new_admin_product_path,
            class: "btn btn-primary" %>
      </div>
    </div>
    <!-- Category Filters -->
    <div class="row">
      <div class="col-md-12">
        <div class="product-filters">
          <ul>
            <li class="<%= 'active' if params[:category].blank? %>">
              <%= link_to "All",
                  admin_products_path,
                  style: "color: black;" %>
            </li>
            <% @categories.each do |category| %>
              <li class="<%= 'active' if params[:category] == category.name %>">
                <%= link_to category.name,
                    admin_products_path(category: category.name),
                    style: "color: black;" %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
    <!-- Products -->
    <div class="row product-lists">
      <% if @products.any? %>
        <% @products.each do |product| %>
          <div class="col-lg-4 col-md-6 text-center <%= product.category&.name&.parameterize %>">
            <div class="single-product-item">
              <div class="product-image">
                <%= link_to admin_product_path(product) do %>
                  <%= image_tag product.image_path, alt: product.name %>
                <% end %>
              </div>
              <h3><%= product.name %></h3>
              <p class="product-price">
                <span>Per Unit</span>
                <%= number_to_currency(product.price) %>
              </p>
              <p>
                <strong>Stock:</strong>
                <%= product.stock_quantity %>
              </p>
              <p>
                <strong>Category:</strong>
                <%= product.category&.name %>
              </p>
              <!-- Admin Buttons -->
              <div class="mt-3">
                <%= link_to "View",
                    admin_product_path(product),
                    class: "btn btn-info btn-sm" %>
                <%= link_to "Edit",
                    edit_admin_product_path(product),
                    class: "btn btn-warning btn-sm" %>
                <% if product.active? %>

                <%= button_to "Deactivate",
                    toggle_active_admin_product_path(product),
                    method: :patch,
                    class: "btn btn-warning btn-sm" %>

                <% else %>

                <%= button_to "Activate",
                    toggle_active_admin_product_path(product),
                    method: :patch,
                    class: "btn btn-success btn-sm" %>

                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="col-md-12 text-center">
          <h2>No products available</h2>
        </div>
      <% end %>
    </div>
  </div>
</div>
<!-- end products -->