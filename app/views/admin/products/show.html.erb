<% content_for :title, "Product Details" %>

<% content_for :_1st, "Products" %>
<% content_for :_2nd, @product.name %>

<div class="product-section mt-150 mb-150">
  <div class="container">

    <div class="row">

      <!-- Product Image -->
      <div class="col-md-6 text-center">
        <div class="single-product-img">
          <%= image_tag @product.image_path, alt: @product.name, class: "img-fluid" %>
        </div>
      </div>

      <!-- Product Info -->
      <div class="col-md-6">

        <h2><%= @product.name %></h2>

        <p class="product-price">
          <span>Price</span>
          <%= number_to_currency(@product.price) %>
        </p>

        <p>
          <strong>Stock Quantity:</strong>
          <%= @product.stock_quantity %>
        </p>

        <p>
          <strong>Category:</strong>
          <%= @product.category&.name %>
        </p>

        <p>
          <strong>Status:</strong>

          <% if @product.active? %>
            <span class="badge bg-success">Active</span>
          <% else %>
            <span class="badge bg-danger">Inactive</span>
          <% end %>
        </p>

        <!-- Admin Buttons -->
        <div class="mt-4">

          <%= link_to "Edit",
              edit_admin_product_path(@product),
              class: "btn btn-warning" %>

          <% if @product.active? %>

            <%= button_to "Deactivate",
                toggle_active_admin_product_path(@product),
                method: :patch,
                class: "btn btn-danger" %>

          <% else %>

            <%= button_to "Activate",
                toggle_active_admin_product_path(@product),
                method: :patch,
                class: "btn btn-success" %>

          <% end %>

          <%= link_to "Back to Products",
              admin_products_path,
              class: "btn btn-secondary" %>

        </div>

      </div>

    </div>

  </div>
</div>