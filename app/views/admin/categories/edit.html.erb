<% content_for :title, "Edit Category" %>

<div class="container mt-5">
  <h2>Edit Category</h2>

  <%= form_with model: [:admin, @category] do |f| %>

    <div class="mb-3">
      <%= f.label :name %>
      <%= f.text_field :name, class: "form-control" %>
    </div>
    <div class="mb-3">
      <%= f.label :image_path %>
      <%= f.text_field :image_path, class: "form-control" %>
    </div>

    <%= f.submit "Update Category", class: "btn btn-success" %>
    <%= link_to "Back", admin_categories_path, class: "btn btn-secondary" %>

  <% end %>
</div>